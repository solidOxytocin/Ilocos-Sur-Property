{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/properties",
      "destination": "/properties.html"
    },
    {
      "source": "/details",
      "destination": "/details.html"
    },
    {
      "source": "/details/:id",
      "destination": "/details/_fallback.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
