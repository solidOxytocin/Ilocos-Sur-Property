# Frontend Environment Variables Template
# Do NOT place real secrets in this file. It is safely committed to source control.
# Copy this file to '.env' and fill in the values on new machines.

EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=""
EXPO_PUBLIC_API_URL="http://localhost:3000"

# JWT for /admin/* (must include { "role": "admin" }), signed with backend ADMIN_JWT_SECRET.
# Mint locally: node -e "const j=require('jsonwebtoken');console.log(j.sign({sub:'admin',role:'admin'},'YOUR_SECRET',{expiresIn:'30d'}))"
EXPO_PUBLIC_ADMIN_TOKEN=""

